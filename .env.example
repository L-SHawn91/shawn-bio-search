# Shawn-Bio-Search API Keys (Optional)
# Copy this file to .env and fill in your API keys
# Free tier available for all services

# PubMed/NCBI (optional but recommended)
# Get key: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_key_here

# Scopus (optional, requires institutional access)
# Contact your institution's library
SCOPUS_API_KEY=your_scopus_key_here
SCOPUS_INSTTOKEN=your_scopus_token_here

# SerpAPI for Google Scholar (optional)
# Get key: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here
